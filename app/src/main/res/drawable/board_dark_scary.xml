<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape>
            <gradient
                android:startColor="@color/scary_magma_1"
                android:centerColor="@color/scary_magma_2"
                android:endColor="@color/scary_gray"
                android:angle="270" />
            <corners android:radius="26dp" />
            <stroke
                android:width="3dp"
                android:color="@color/scary_red_light" />
        </shape>
    </item>

    <item
        android:left="10dp"
        android:top="10dp"
        android:right="10dp"
        android:bottom="10dp">
        <shape>
            <solid android:color="#1A1111" />
            <corners android:radius="20dp" />
            <stroke
                android:width="1dp"
                android:color="#3A1B1B" />
        </shape>
    </item>

</layer-list>