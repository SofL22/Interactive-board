<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Degradado estilo Frutiger -->
    <gradient
        android:startColor="#6EC6FF"
        android:endColor="#4CAF50"
        android:angle="45" />

    <!-- Bordes redondeados suaves -->
    <corners android:radius="20dp"/>

    <!-- Borde ligero -->
    <stroke
        android:width="1dp"
        android:color="#80FFFFFF"/>

    <!-- Espaciado interno -->
    <padding
        android:left="16dp"
        android:top="10dp"
        android:right="16dp"
        android:bottom="10dp"/>
</shape>