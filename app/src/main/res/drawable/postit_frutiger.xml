<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Gradiente tipo glass -->
    <gradient
        android:startColor="#87CEEB"
        android:endColor="#7CFC00"
        android:angle="270"/>

    <!-- Borde suave -->
    <stroke
        android:width="2dp"
        android:color="#4FC3F7"/>

    <!-- Bordes redondeados -->
    <corners android:radius="20dp"/>

    <!-- Efecto brillo (simulado) -->
    <padding
        android:left="12dp"
        android:top="12dp"
        android:right="12dp"
        android:bottom="12dp"/>
</shape>

