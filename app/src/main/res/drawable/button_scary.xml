<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <shape>
            <gradient
                android:startColor="#FF3B30"
                android:endColor="#7A0C0C"
                android:angle="270" />
            <corners android:radius="18dp" />
            <stroke
                android:width="2dp"
                android:color="#FFD6D6" />
        </shape>
    </item>

    <item>
        <shape>
            <gradient
                android:startColor="#7A0C0C"
                android:endColor="#C1121F"
                android:angle="270" />
            <corners android:radius="18dp" />
            <stroke
                android:width="2dp"
                android:color="#3A0B0B" />
        </shape>
    </item>

</selector>