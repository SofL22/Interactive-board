<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape>
            <gradient
                android:startColor="@color/nature_green_1"
                android:centerColor="#DFF5D8"
                android:endColor="#F6FFF1"
                android:angle="270" />
            <corners android:radius="26dp" />
            <stroke
                android:width="3dp"
                android:color="@color/nature_stroke" />
        </shape>
    </item>

    <item
        android:left="10dp"
        android:top="10dp"
        android:right="10dp"
        android:bottom="10dp">
        <shape>
            <solid android:color="#F8FFF5" />
            <corners android:radius="20dp" />
            <stroke
                android:width="1dp"
                android:color="#C8E6C9" />
        </shape>
    </item>

</layer-list>